{
	"name": "util-bot-v3",
	"version": "1.0.0",
	"description": "discordのチャンネルに投稿された画像を取得し、バックアップするbot",
	"license": "MIT",
	"author": "nanaios",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"start": "docker compose up --build",
		"build": "node esbuild.mjs",
		"test": "npx vitest",
		"build_image": "docker build -t 192.168.0.168:5000/discord-util-bot-v3:%npm_package_version% .",
		"push_image": "docker push 192.168.0.168:5000/discord-util-bot-v3:%npm_package_version%"
	},
	"dependencies": {
		"discord.js": "14.26.4",
		"dotenv": "17.4.2",
		"mysql2": "3.22.5",
		"squel": "6.3.1"
	},
	"devDependencies": {
		"@types/mysql": "2.15.27",
		"@types/node": "22.13.1",
		"esbuild": "0.28.1",
		"typescript": "6.0.3",
		"vitest": "4.1.9"
	}
}