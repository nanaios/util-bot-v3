{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "esnext",
		"jsx": "react-jsx",
		"checkJs": true,
		"allowJs": true,
		"skipLibCheck": true,
		"experimentalDecorators": true,
		"strictNullChecks": true,
		"strictFunctionTypes": true,
		"strict": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"paths": {
			"@/*": [
				"./src/*"
			]
		},
		"types": [
			"node"
		]
	},
	"include": [
		"./src/**/*",
		"./test/**/*"
	],
	"exclude": [
		"dist",
		"esbuild.mjs",
		"vitest.config.ts",
		"node_modules",
		"**/node_modules/*"
	]
}